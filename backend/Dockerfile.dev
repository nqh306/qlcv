# syntax=docker/dockerfile:1.7
FROM python:3.12.10-alpine AS backend

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    INSTANCE_CHANGELOG_URL=https://ems.evngenco1.vn/qlcv

WORKDIR /code

# Runtime + build deps in one layer
RUN apk add --no-cache \
        bash \
        libpq \
        libxslt \
        xmlsec \
        nodejs-current \
        gcc \
        g++ \
        cargo \
        git \
        make \
        libffi-dev \
        postgresql-dev \
        libc-dev \
        linux-headers

COPY requirements.txt ./
COPY requirements ./requirements

# Install local dev requirements with pip cache mount
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -r requirements/local.txt --compile

COPY . .

RUN mkdir -p /code/qlcv/logs && chmod -R +x /code/bin

EXPOSE 8000

CMD [ "./bin/docker-entrypoint-api-local.sh" ]
